do_install() {
	vcopy include usr/include
	mkdir -p /usr/include/half
	# I couldn't get the defines in MIOpen to behave so now it's linked
	ln -sf /usr/include/half.hpp /usr/include/half/half.hpp
	vlicense LICENSE.txt
}
